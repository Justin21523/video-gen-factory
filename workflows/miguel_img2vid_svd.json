{
  "1": {
    "inputs": {
      "image": "miguel_ref_face.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {
      "title": "Load Miguel Reference Image"
    }
  },
  "2": {
    "inputs": {
      "width": 1024,
      "height": 576,
      "upscale_method": "lanczos",
      "crop": "center",
      "image": ["1", 0]
    },
    "class_type": "ImageScale",
    "_meta": {
      "title": "Resize to 1024x576"
    }
  },
  "3": {
    "inputs": {
      "ckpt_name": "svd_xt.safetensors"
    },
    "class_type": "ImageOnlyCheckpointLoader",
    "_meta": {
      "title": "Load SVD XT Model"
    }
  },
  "4": {
    "inputs": {
      "width": 1024,
      "height": 576,
      "video_frames": 25,
      "motion_bucket_id": 127,
      "fps": 6,
      "augmentation_level": 0.0,
      "clip_vision": ["3", 1],
      "init_image": ["2", 0],
      "vae": ["3", 2]
    },
    "class_type": "SVD_img2vid_Conditioning",
    "_meta": {
      "title": "SVD Conditioning (25 frames)"
    }
  },
  "5": {
    "inputs": {
      "seed": 123789456,
      "steps": 20,
      "cfg": 2.5,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["3", 0],
      "positive": ["4", 0],
      "negative": ["4", 1],
      "latent_image": ["4", 2]
    },
    "class_type": "KSampler",
    "_meta": {
      "title": "KSampler SVD"
    }
  },
  "6": {
    "inputs": {
      "samples": ["5", 0],
      "vae": ["3", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {
      "title": "VAE Decode"
    }
  },
  "7": {
    "inputs": {
      "frame_rate": 6,
      "loop_count": 0,
      "filename_prefix": "miguel_svd",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 18,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true,
      "images": ["6", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": {
      "title": "Save SVD Video (6fps)"
    }
  },
  "8": {
    "inputs": {
      "interpolation": "lanczos",
      "keep_model_loaded": false,
      "multiplier": 5,
      "optional_interpolation_states": "",
      "frames": ["6", 0]
    },
    "class_type": "VHS_RIFE",
    "_meta": {
      "title": "Frame Interpolation (6fps -> 30fps)"
    }
  },
  "9": {
    "inputs": {
      "frame_rate": 30,
      "loop_count": 0,
      "filename_prefix": "miguel_svd_30fps",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 18,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true,
      "images": ["8", 0]
    },
    "class_type": "VHS_VideoCombine",
    "_meta": {
      "title": "Save Interpolated Video (30fps)"
    }
  }
}
